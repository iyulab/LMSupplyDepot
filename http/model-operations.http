@baseUrl = http://localhost:5181
@apiBase = {{baseUrl}}/api

### Explicit model loading (NOW AVAILABLE)
POST {{apiBase}}/models/load
Content-Type: application/json

{
  "model": "llama-3-8b",
  "parameters": {
    "gpu_layers": 26,
    "threads": 4,
    "context_size": 4096,
    "batch_size": 512
  }
}

### Load model by full ID
POST {{apiBase}}/models/load
Content-Type: application/json

{
  "model": "hf:bartowski/Llama-3.2-3B-Instruct-GGUF/Llama-3.2-3B-Instruct-IQ3_M",
  "parameters": {
    "gpu_layers": 20,
    "threads": 8
  }
}

### Unload a model (NOW AVAILABLE)
POST {{apiBase}}/models/unload
Content-Type: application/json

{
  "model": "llama-3-8b"
}

### Unload model by full ID
POST {{apiBase}}/models/unload
Content-Type: application/json

{
  "model": "hf:bartowski/Llama-3.2-3B-Instruct-GGUF/Llama-3.2-3B-Instruct-IQ3_M"
}

### Get loaded models (NOW AVAILABLE)
GET {{apiBase}}/models/loaded
Accept: application/json

### Check if model is loaded (implicit through generation)
POST {{apiBase}}/v1/chat/completions
Content-Type: application/json

{
  "model": "llama-3-8b",
  "prompt": "Hello, world!",
  "maxTokens": 10,
  "stream": false
}

### Test model loading with generation (implicit loading)
POST {{apiBase}}/v1/chat/completions
Content-Type: application/json

{
  "model": "hf:bartowski/Llama-3.2-3B-Instruct-GGUF/Llama-3.2-3B-Instruct-IQ3_M",
  "prompt": "Write a hello world program in Python.",
  "maxTokens": 100,
  "temperature": 0.7,
  "stream": false
}

### Test embedding model operations
POST {{apiBase}}/models/load
Content-Type: application/json

{
  "model": "hf:sentence-transformers/all-MiniLM-L6-v2",
  "parameters": {
    "gpu_layers": 0,
    "threads": 4
  }
}

### Generate embeddings (implicit loading if needed)
POST {{apiBase}}/v1/embeddings
Content-Type: application/json

{
  "model": "embedding-model",
  "texts": [
    "This is a test sentence.",
    "Another sentence for embedding."
  ],
  "normalize": true
}

### Model status operations

### Check download status
GET {{apiBase}}/downloads/llama-3-8b/status
Accept: application/json

### Check if model is downloaded
GET {{apiBase}}/models/llama-3-8b/downloaded
Accept: application/json

### Get active downloads
GET {{apiBase}}/downloads
Accept: application/json